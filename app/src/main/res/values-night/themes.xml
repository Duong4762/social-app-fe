<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for dark mode. -->
    <style name="Base.Theme.Socialapp" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Colors -->
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_purple_light</item>
        <item name="colorOnSecondary">@color/dark_bg_primary</item>
        <item name="colorSurface">@color/dark_bg_primary</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="android:colorBackground">@color/dark_bg_primary</item>
        <item name="colorOnBackground">@color/dark_text_primary</item>
        <item name="colorSurfaceVariant">@color/dark_bg_secondary</item>
        <item name="colorOnSurfaceVariant">@color/dark_text_secondary</item>
        <item name="colorOutline">@color/dark_bg_tertiary</item>
        <item name="colorSecondaryContainer">@color/dark_bg_tertiary</item>
        <item name="colorOnSecondaryContainer">@color/dark_text_primary</item>

        <!-- Typography - Apply Inter Font Family Globally -->
        <item name="android:fontFamily">@font/inter</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Title.Large</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Title.Medium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Title.Small</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Subtitle.Bold</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Heading3</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Body.Large</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Body.Medium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Body.Small</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Button</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Caption</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.PostTime</item>
    </style>

    <style name="Theme.Socialapp" parent="Base.Theme.Socialapp" />
</resources>