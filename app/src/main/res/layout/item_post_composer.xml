<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?attr/colorSurface">

    <FrameLayout
        android:id="@+id/composer_avatar_ring_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:id="@+id/composer_story_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/composer_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:background="@color/avatar_background"
            android:contentDescription="@string/user_avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_placeholder"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.SocialApp.Circle" />
    </FrameLayout>

    <!-- What's new? Button (MaterialButton) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/composer_input"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="?attr/colorSurfaceVariant"
        android:text="@string/composer_placeholder"
        android:gravity="center_vertical|start"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:cornerRadius="20dp"
        app:layout_constraintStart_toEndOf="@id/composer_avatar_ring_container"
        app:layout_constraintEnd_toStartOf="@id/composer_image_btn"
        app:layout_constraintTop_toTopOf="@id/composer_avatar_ring_container"
        app:layout_constraintBottom_toBottomOf="@id/composer_avatar_ring_container" />

    <!-- Image Icon Button -->
    <ImageButton
        android:id="@+id/composer_image_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_composer_image"
        android:contentDescription="@string/icon_image"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerInside"
        app:tint="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/composer_avatar_ring_container"
        app:layout_constraintBottom_toBottomOf="@id/composer_avatar_ring_container"
        android:layout_marginEnd="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
