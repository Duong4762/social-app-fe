<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/chat_out_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_chat_bubble_out"
        android:maxWidth="280dp"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        android:textColor="@color/white"
        android:textSize="15sp"
        tools:text="I'm good, thanks!" />

    <ImageView
        android:id="@+id/chat_out_image"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="end"
        android:adjustViewBounds="true"
        android:background="@color/avatar_background"
        android:contentDescription="@string/post_image"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chat_out_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            tools:text="10:44 AM" />

        <TextView
            android:id="@+id/chat_out_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/chat_tick_sent"
            android:textColor="@color/primary_purple"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
