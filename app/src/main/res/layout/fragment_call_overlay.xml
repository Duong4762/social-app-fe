<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/call_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0121212"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/call_peer_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@color/avatar_background"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.38"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.SocialApp.Circle" />

        <TextView
            android:id="@+id/call_peer_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/call_peer_avatar"
            tools:text="Người dùng" />

        <TextView
            android:id="@+id/call_status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:alpha="0.85"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/call_peer_name"
            tools:text="Đang chờ…" />

        <LinearLayout
            android:id="@+id/call_row_incoming_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/call_btn_accept"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginEnd="20dp"
                android:minWidth="140dp"
                android:text="@string/call_accept"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/call_accept_green"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/call_btn_decline"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:minWidth="140dp"
                android:text="@string/call_decline"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/call_decline_red"
                app:cornerRadius="28dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/call_row_active_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageButton
                android:id="@+id/call_btn_speaker"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="48dp"
                android:background="@drawable/bg_call_speaker_circle"
                android:contentDescription="@string/call_speaker"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_speaker" />

            <ImageButton
                android:id="@+id/call_btn_hangup"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="48dp"
                android:background="@drawable/bg_call_end_circle"
                android:contentDescription="@string/call_hangup"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_phone_white" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
