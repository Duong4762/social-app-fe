<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- AppBar -->
    <LinearLayout
        android:id="@+id/appbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp"
        android:background="?attr/colorSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:id="@+id/cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingEnd="10dp"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/new_post"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:textSize="18sp" />
    </LinearLayout>
    <!-- Divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        app:layout_constraintBottom_toTopOf="@+id/bottom_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Avatar + Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/user_avatar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/avatar_placeholder"
                    android:background="@drawable/bg_circle"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/user_avatar"/>
                <EditText
                    android:id="@+id/post_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/write_something"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:textSize="16sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="5dp"
                    android:inputType="textMultiLine"
                    android:maxLines="3"/>
            </LinearLayout>

            <!-- Media Preview -->
            <LinearLayout
                android:id="@+id/media_preview_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">
            </LinearLayout>

            <!-- MEDIA UPLOAD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/media_upload"
                android:textAllCaps="true"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- Upload Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="22dp"
                android:gravity="center">
                <Button
                    android:id="@+id/upload_image_button"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:backgroundTint="?attr/colorPrimary"
                    android:text="@string/upload_image"
                    android:textColor="?attr/colorOnPrimary"
                    android:drawableStart="@drawable/ic_composer_image"
                    android:textAllCaps="false"
                    android:drawablePadding="7dp"/>
                <Space
                    android:layout_width="12dp"
                    android:layout_height="0dp"/>
                <Button
                    android:id="@+id/upload_video_button"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:backgroundTint="?attr/colorPrimary"
                    android:text="@string/upload_video"
                    android:textColor="?attr/colorOnPrimary"
                    android:drawableStart="@drawable/ic_composer_video"
                    android:textAllCaps="false"
                    android:drawablePadding="7dp"/>
            </LinearLayout>

            <!-- Actions List -->
            <LinearLayout
                android:id="@+id/quick_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Add Location -->
                <include
                    android:id="@+id/add_location_row"
                    layout="@layout/item_row_action"/>
                <View android:layout_height="1dp" android:layout_width="match_parent" android:background="?attr/colorOutlineVariant" />

                <!-- Tag People -->
                <include
                    android:id="@+id/tag_people_row"
                    layout="@layout/item_row_tag"/>
                <View android:layout_height="1dp" android:layout_width="match_parent" android:background="?attr/colorOutlineVariant" />

                <!-- Audience -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_audience"
                        app:tint="?attr/colorPrimary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="13dp"
                        android:text="@string/audience"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp" />
                    <Spinner
                        android:id="@+id/privacy_spinner"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_spinner_audience"
                        android:entries="@array/privacy_options"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:textAlignment="viewStart"
                        android:popupBackground="?attr/colorSurface"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/camera_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_fab_button"
            android:src="@drawable/ic_composer_emoji"
            android:contentDescription="@string/camera"/>
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp" />
        <Button
            android:id="@+id/post_button"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:backgroundTint="?attr/colorPrimary"
            android:text="@string/post"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnPrimary"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>