<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- AppBar -->
    <LinearLayout
        android:id="@+id/appbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp"
        android:background="?attr/colorSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageButton
            android:id="@+id/cancel_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/cancel"
            app:tint="?attr/colorOnSurface"
            android:padding="6dp"/>
        <TextView
            android:id="@+id/new_post_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/new_post"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:textSize="18sp" />
    </LinearLayout>
    <!-- Divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        app:layout_constraintBottom_toTopOf="@+id/bottom_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Avatar + Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/user_avatar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@color/avatar_background"
                    android:contentDescription="@string/user_avatar"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_placeholder"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.SocialApp.Circle" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/post_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="40dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/write_something"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:textSize="16sp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:inputType="textMultiLine"
                        android:maxLines="10"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Photo Section -->
            <TextView
                android:id="@+id/photo_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Images"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>
            <HorizontalScrollView
                android:id="@+id/photo_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone">
                <LinearLayout
                    android:id="@+id/photo_preview_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Video Section -->
            <TextView
                android:id="@+id/video_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Videos"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>
            <HorizontalScrollView
                android:id="@+id/video_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone">
                <LinearLayout
                    android:id="@+id/video_preview_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                </LinearLayout>
            </HorizontalScrollView>

            <!-- MEDIA UPLOAD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/media_upload"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- Upload Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="22dp"
                android:gravity="center">
                <Button
                    android:id="@+id/upload_image_button"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/primary"
                    android:text="@string/upload_image"
                    android:textColor="?attr/colorSurface"
                    android:drawableStart="@drawable/ic_composer_image"
                    android:textAllCaps="false"
                    android:drawablePadding="7dp"/>
                <Space
                    android:layout_width="12dp"
                    android:layout_height="0dp"/>
                <Button
                    android:id="@+id/upload_video_button"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/primary"
                    android:text="@string/upload_video"
                    android:textColor="?attr/colorSurface"
                    android:drawableStart="@drawable/ic_composer_video"
                    android:textAllCaps="false"
                    android:drawablePadding="7dp"/>
            </LinearLayout>

            <!-- Actions List -->
            <!-- REMOVED: Add Location, Tag People, Audience -->

        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/camera_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_fab_button"
            android:src="@drawable/ic_camera"
            android:contentDescription="@string/camera"
            app:tint="?attr/colorSurface"/>
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp" />
        <Button
            android:id="@+id/post_button"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:backgroundTint="@color/primary"
            android:text="@string/post"
            android:textAllCaps="false"
            android:textColor="?attr/colorSurface"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
