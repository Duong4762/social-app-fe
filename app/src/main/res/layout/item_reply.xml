<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Reply item with indentation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:layout_marginStart="28dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/reply_avatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/user_avatar"
            android:src="@drawable/avatar_placeholder"
            android:scaleType="centerCrop" />

        <!-- Content Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/rounded_comment_card"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <!-- Username + Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/reply_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:id="@+id/reply_verified_badge"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="3dp"
                    android:contentDescription="@string/verified"
                    android:visibility="gone"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Reply text -->
            <TextView
                android:id="@+id/reply_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/reply_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action Buttons for Reply -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="72dp"
        android:layout_marginTop="2dp">

        <!-- Like -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="2dp"
            android:paddingEnd="8dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/reply_like_button"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/like"
                android:padding="0dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_heart"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/reply_like_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- Reply -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="2dp"
            android:paddingEnd="8dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/reply_reply_button"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/reply"
                android:padding="0dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_comment"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/reply_reply_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="2dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

