<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:elevation="2dp">

    <!-- Post Container Card Padding -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/post_content_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- User Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/post_user_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@color/avatar_background"
            android:contentDescription="@string/user_avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.SocialApp.Circle" />

        <!-- Username -->
        <TextView
            android:id="@+id/post_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            style="@style/TextAppearance.Feed.Username"
            app:layout_constraintStart_toEndOf="@id/post_user_avatar"
            app:layout_constraintEnd_toStartOf="@id/post_more_options"
            app:layout_constraintTop_toTopOf="@id/post_user_avatar" />

        <!-- More Options -->
        <ImageButton
            android:id="@+id/post_more_options"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_horiz"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/post_user_avatar"
            app:layout_constraintBottom_toBottomOf="@id/post_user_avatar"
            app:tint="?attr/colorOnSurface" />

        <!-- Timestamp and Location -->
        <LinearLayout
            android:id="@+id/post_meta_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toEndOf="@id/post_user_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/post_username">

            <TextView
                android:id="@+id/post_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Feed.Time"
                android:text="2 HOURS AGO" />

            <TextView
                android:id="@+id/post_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                style="@style/TextAppearance.Feed.Time"
                android:text="KYOTO, JAPAN" />

        </LinearLayout>

        <!-- Post Content Text -->
        <TextView
            android:id="@+id/post_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/TextAppearance.Feed.Content"
            android:lineSpacingExtra="4sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/post_meta_layout" />

        <!-- Post Media Container (ViewPager2 for multiple images) -->
        <FrameLayout
            android:id="@+id/post_media_container"
            android:layout_width="0dp"
            android:layout_height="300dp"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/post_content">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/post_view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/media_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/bg_indicator"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="1/3" />
        </FrameLayout>

        <!-- Action Bar -->
        <LinearLayout
            android:id="@+id/post_actions_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/post_media_container">

            <!-- Like Button -->
            <LinearLayout
                android:id="@+id/post_like_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/post_like_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/action_like"
                    android:src="@drawable/ic_heart"
                    android:scaleType="centerInside"
                    app:tint="?attr/colorOnSurface"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:id="@+id/post_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    style="@style/TextAppearance.Feed.ActionCount"
                    android:text="245" />

            </LinearLayout>

            <!-- Comment Button -->
            <LinearLayout
                android:id="@+id/post_comment_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/post_comment_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/action_comment"
                    android:src="@drawable/ic_comment"
                    android:scaleType="centerInside"
                    app:tint="?attr/colorOnSurface"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:id="@+id/post_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    style="@style/TextAppearance.Feed.ActionCount"
                    android:text="42" />

            </LinearLayout>

            <!-- Share Button -->
            <LinearLayout
                android:id="@+id/post_share_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/post_share_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/action_share"
                    android:src="@drawable/ic_share"
                    android:scaleType="centerInside"
                    app:tint="?attr/colorOnSurface"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:id="@+id/post_share_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    style="@style/TextAppearance.Feed.ActionCount"
                    android:text="18" />

            </LinearLayout>

            <!-- Bookmark Button -->
            <ImageView
                android:id="@+id/post_bookmark_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/action_bookmark"
                android:src="@drawable/ic_bookmark"
                android:scaleType="centerInside"
                app:tint="?attr/colorOnSurface"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/post_content_container" />

</androidx.constraintlayout.widget.ConstraintLayout>

