<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.example.social_app.widgets.AvatarCropperView
        android:id="@+id/avatarCropperView"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@android:color/transparent" />

    <TextView
        android:id="@+id/tvChangeAvatarAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:text="@string/profile_change_avatar"
        android:textColor="@color/primary_blue"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSaveAvatar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/primary_blue"
        android:text="@string/profile_save_avatar"
        android:textAllCaps="false"
        android:textColor="?attr/colorSurface" />

</LinearLayout>
