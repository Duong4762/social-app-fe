<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="450dp"
    android:background="?attr/colorSurface">

    <!-- Drag Handle Container -->
    <FrameLayout
        android:id="@+id/drag_handle_container"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/drag_handle"
            android:layout_width="40dp"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:background="@drawable/drag_handle"
            android:contentDescription="@string/drag_handle_desc"/>
    </FrameLayout>

    <!-- SwipeRefreshLayout + RecyclerView - Takes remaining space -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:minHeight="200dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/drag_handle_container"
        app:layout_constraintBottom_toTopOf="@id/comment_compose_container"
        app:layout_constraintVertical_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/comments_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:nestedScrollingEnabled="true" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Comment Compose Section at Bottom -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/comment_compose_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/swipe_refresh_layout"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Row 1: Avatar + Input + Char Count -->
        <ImageView
            android:id="@+id/compose_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/user_avatar"
            android:src="@drawable/avatar_placeholder"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/compose_action_buttons_section"
            app:layout_constraintVertical_chainStyle="packed"/>

        <EditText
            android:id="@+id/compose_comment_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/rounded_edittext"
            android:hint="@string/compose_hint_comment"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:maxLines="3"
            android:minLines="1"
            android:minHeight="36dp"
            app:layout_constraintStart_toEndOf="@id/compose_avatar"
            app:layout_constraintEnd_toStartOf="@id/compose_char_count_text"
            app:layout_constraintTop_toTopOf="@id/compose_avatar"
            app:layout_constraintBottom_toBottomOf="@id/compose_avatar"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/compose_selected_media_container"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/compose_comment_input"
            app:layout_constraintStart_toStartOf="@id/compose_comment_input">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/compose_selected_media_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:background="@android:color/black" />

                <ImageButton
                    android:id="@+id/compose_selected_media_remove"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cancel"
                    android:padding="6dp"
                    android:src="@drawable/ic_close"
                    app:tint="@android:color/white" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/compose_char_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/280"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="@id/compose_comment_input"
            app:layout_constraintBottom_toBottomOf="@id/compose_comment_input"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 2: Action Buttons (Emoji, Send) -->
        <LinearLayout
            android:id="@+id/compose_action_buttons_section"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/compose_selected_media_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/compose_attach_media_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/attach_media"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_composer_image"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/compose_emoji_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/emoji"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_composer_emoji"
                app:tint="?attr/colorOnSurfaceVariant" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageButton
                android:id="@+id/compose_send_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/send"
                android:enabled="false"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/send_message"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/media_send_button"
        android:layout_width="120dp"
        android:layout_height="46dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/primary_blue"
        android:text="@string/send"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="23dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>










