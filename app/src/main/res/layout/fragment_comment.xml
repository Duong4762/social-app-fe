<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="450dp"
    android:background="?attr/colorSurface">

    <!-- Drag Handle -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@drawable/drag_handle"
        android:contentDescription="@string/drag_handle_desc"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/comment_sort_spinner"
        app:layout_constraintVertical_chainStyle="packed"/>

    <!-- Spinner -->
    <Spinner
        android:id="@+id/comment_sort_spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:layout_constraintBottom_toTopOf="@id/swipe_refresh_layout"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- SwipeRefreshLayout + RecyclerView - Takes remaining space -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:minHeight="200dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/comment_sort_spinner"
        app:layout_constraintBottom_toTopOf="@id/comment_compose_container"
        app:layout_constraintVertical_weight="1"
        app:layout_constraintVertical_chainStyle="spread">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/comments_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:nestedScrollingEnabled="false" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Comment Compose Section at Bottom -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/comment_compose_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/swipe_refresh_layout"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Row 1: Avatar + Input + Char Count -->
        <ImageView
            android:id="@+id/compose_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/user_avatar"
            android:src="@drawable/avatar_placeholder"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/compose_action_buttons_section"
            app:layout_constraintVertical_chainStyle="packed"/>

        <EditText
            android:id="@+id/compose_comment_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/rounded_edittext"
            android:hint="@string/write_a_comment"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:maxLines="3"
            android:minLines="1"
            app:layout_constraintStart_toEndOf="@id/compose_avatar"
            app:layout_constraintEnd_toStartOf="@id/compose_char_count_text"
            app:layout_constraintTop_toTopOf="@id/compose_avatar"
            app:layout_constraintBottom_toBottomOf="@id/compose_avatar"/>

        <TextView
            android:id="@+id/compose_char_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/280"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="@id/compose_comment_input"
            app:layout_constraintBottom_toBottomOf="@id/compose_comment_input"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 2: Action Buttons (Image, GIF, Emoji, Send) -->
        <LinearLayout
            android:id="@+id/compose_action_buttons_section"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/compose_comment_input"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/compose_attach_media_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/attach_media"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_composer_image"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/compose_gif_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/gif"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_composer_gif"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/compose_emoji_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/emoji"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_composer_emoji"
                app:tint="?attr/colorOnSurfaceVariant" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/compose_send_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/send"
                android:enabled="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_send"
                android:tint="@android:color/white"
                app:backgroundTint="@color/primary_purple"
                app:fabSize="mini"
                app:fabCustomSize="40dp"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>










