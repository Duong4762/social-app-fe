<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Main comment layout: Avatar + Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/comment_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/user_avatar"
            android:src="@drawable/avatar_placeholder"
            android:scaleType="centerCrop" />

        <!-- Content Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/rounded_comment_card"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Username + Badge + Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/comment_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:id="@+id/verified_badge"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@string/verified"
                    android:visibility="gone"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/comment_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Comment text -->
            <TextView
                android:id="@+id/comment_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/comment_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="44dp"
        android:layout_marginTop="4dp">

        <!-- Like -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/comment_like_button"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/like"
                android:padding="0dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_heart"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/comment_like_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Reply -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/comment_reply_button"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/reply"
                android:padding="0dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_comment"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/comment_reply_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- View more replies button -->
    <TextView
        android:id="@+id/view_more_replies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/primary_purple"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:background="?android:attr/selectableItemBackground" />
</LinearLayout>

