<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:layout_margin="8dp"
    android:padding="12dp">

    <!-- User Avatar -->
    <ImageView
        android:id="@+id/comment_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/user_avatar"
        android:scaleType="centerCrop"
        android:src="@drawable/avatar_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- User Info Section: Username + Timestamp -->
    <LinearLayout
        android:id="@+id/user_info_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toEndOf="@id/comment_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/comment_avatar">

        <!-- Username (Bold) -->
        <TextView
            android:id="@+id/comment_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="John Doe" />

        <!-- Verification Badge (if applicable) -->
        <ImageView
            android:id="@+id/verified_badge"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/verified"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_verified"
            android:visibility="gone" />

        <!-- Spacer -->
        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <!-- Timestamp (Smaller text) -->
        <TextView
            android:id="@+id/comment_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            tools:text="2 HOURS AGO" />

    </LinearLayout>

    <!-- Location Info (Optional) -->
    <LinearLayout
        android:id="@+id/location_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/comment_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/user_info_section">

        <!-- Location Icon -->
        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:contentDescription="@string/location"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_location"
            app:tint="?attr/colorOnSurfaceVariant" />

        <!-- Location Text -->
        <TextView
            android:id="@+id/comment_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            tools:text="KYOTO, JAPAN" />

    </LinearLayout>

    <!-- Comment Text with Rounded Background -->
    <TextView
        android:id="@+id/comment_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/comment_text_background"
        android:padding="10dp"
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp"
        android:textIsSelectable="true"
        app:layout_constraintStart_toEndOf="@id/comment_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/location_section"
        tools:text="This is a great post! Love the content and the way it's presented." />

    <!-- Action Buttons Row -->
    <LinearLayout
        android:id="@+id/action_buttons_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toEndOf="@id/comment_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/comment_text">

        <!-- Like Count + Icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Like Icon -->
            <ImageButton
                android:id="@+id/comment_like_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/like"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_heart"
                app:tint="?attr/colorOnSurfaceVariant" />

            <!-- Like Count Text -->
            <TextView
                android:id="@+id/comment_like_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="124" />

        </LinearLayout>

        <!-- Comment/Reply Count + Icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Reply Icon -->
            <ImageButton
                android:id="@+id/comment_reply_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/reply"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_comment"
                app:tint="?attr/colorOnSurfaceVariant" />

            <!-- Reply Count Text -->
            <TextView
                android:id="@+id/comment_reply_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="12" />

        </LinearLayout>

        <!-- Share Button (Optional) -->
        <ImageButton
            android:id="@+id/comment_share_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/share"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_share"
            android:visibility="gone"
            app:tint="?attr/colorOnSurfaceVariant" />

        <!-- Spacer to push bookmark to right -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Bookmark/Save Button -->
        <ImageButton
            android:id="@+id/comment_bookmark_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/bookmark"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_bookmark"
            app:tint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <!-- View More Replies Link (Optional) -->
    <TextView
        android:id="@+id/view_more_replies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:text="@string/view_more_replies"
        android:textColor="@color/primary_purple"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/comment_avatar"
        app:layout_constraintTop_toBottomOf="@id/action_buttons_section" />

</androidx.constraintlayout.widget.ConstraintLayout>

