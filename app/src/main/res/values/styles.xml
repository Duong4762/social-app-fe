<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================
         TYPOGRAPHY STYLES - INTER FONT FAMILY
         ============================================ -->

    <!-- Title & Heading Styles (Inter Bold - 700 weight) -->

    <!-- Extra Large Title (32sp) -->
    <style name="TextAppearance.Title.ExtraLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Large Title (28sp) -->
    <style name="TextAppearance.Title.Large" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Medium Title (24sp) -->
    <style name="TextAppearance.Title.Medium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Small Title (20sp) -->
    <style name="TextAppearance.Title.Small" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Username Style (16sp - Bold) -->
    <style name="TextAppearance.Username" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Subtitle/Secondary Heading (18sp - Bold) -->
    <style name="TextAppearance.Subtitle.Bold" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Heading 3 (16sp - Bold) -->
    <style name="TextAppearance.Heading3" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- ============================================
         BODY/CONTENT STYLES (Inter Regular/Medium - 400/500 weight)
         ============================================ -->

    <!-- Large Body Text (18sp - Regular) -->
    <style name="TextAppearance.Body.Large" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Medium Body Text (16sp - Regular) - Default for post content -->
    <style name="TextAppearance.Body.Medium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Small Body Text (14sp - Regular) -->
    <style name="TextAppearance.Body.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <!-- Extra Small Body Text (12sp - Regular) -->
    <style name="TextAppearance.Body.ExtraSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <!-- Caption/Label (13sp - Regular) -->
    <style name="TextAppearance.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <!-- Post Time/Timestamp (11sp - Regular) -->
    <style name="TextAppearance.PostTime" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?android:attr/textColorTertiary</item>
    </style>

    <!-- Location Text (13sp - Regular) -->
    <style name="TextAppearance.Location" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <!-- ============================================
         COMPONENT STYLES
         ============================================ -->

    <!-- AppBar Title Style -->
    <style name="TextAppearance.AppBar.Title" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_purple</item>
    </style>

    <!-- Button Text Style (Medium - 500) -->
    <style name="TextAppearance.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Dialog Title Style -->
    <style name="TextAppearance.Dialog.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Dialog Body Style -->
    <style name="TextAppearance.Dialog.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- ============================================
         COMMENT & FEED STYLES
         ============================================ -->

    <!-- Comment Author Name (Bold) -->
    <style name="TextAppearance.Comment.Author" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Comment Content (Regular) -->
    <style name="TextAppearance.Comment.Content" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Post Feed Item Title/Username -->
    <style name="TextAppearance.Feed.Username" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Post Feed Item Time -->
    <style name="TextAppearance.Feed.Time" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <!-- Post Feed Item Content/Description -->
    <style name="TextAppearance.Feed.Content" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Post Action Count (Like/Comment/Share counts) -->
    <style name="TextAppearance.Feed.ActionCount" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <style name="TextAppearance.Search.Tab" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>

